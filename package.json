{
  "name": "fullstack-task-manager",
  "version": "1.0.0",
  "description": "A modern interactive fullstack task manager",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "node backend/server.js",
    "build": "vite build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "jest",
    "test:backend": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "dotenv": "^16.4.5",
    "concurrently": "^8.2.2",
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "react-beautiful-dnd": "^13.1.1",
    "socket.io-client": "^4.7.5",
    "jwt-decode": "^4.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.3.4",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
